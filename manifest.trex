<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.dataqualitygauge.extension" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description resource-id="description"/>
    <author
      name="Data Quality Gauge"
      email="admin@example.com"
      organization="Example Org"
      website="https://example.github.io"/>
    <min-api-version>1.4</min-api-version>
    <source-location>
      <!--
        ╔══════════════════════════════════════════════════════════════╗
        ║  UPDATE THIS URL to your GitHub Pages deployment address.   ║
        ║  Example: https://YOUR-USERNAME.github.io/REPO-NAME/        ║
        ╚══════════════════════════════════════════════════════════════╝
      -->
      <url>https://amankaushik-a11y.github.io/tableau-gauge-custom-extension/</url>
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Data Quality Gauge</text>
    </resource>
    <resource id="description">
      <text locale="en_US">Displays a gauge chart for data quality metrics — shows null rate, total count, invalid count, and threshold-based color coding.</text>
    </resource>
  </resources>
</manifest>
